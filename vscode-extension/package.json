{
    "name": "neurocode-ia",
    "displayName": "NeuroCode · Lenguaje de Programación IA-Nativo",
    "description": "Syntax highlighting, snippets and tools for NeuroCode, the AI-native programming language in Spanish",
    "version": "2.2.0",
    "publisher": "neurocode-ia",
    "license": "MIT",
    "icon": "icon.png",
    "engines": {
        "vscode": "^1.50.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "keywords": [
        "neurocode", "español", "ia", "rust", "programming language"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/juanmanuel767/Neuro-code"
    },
    "contributes": {
        "languages": [{
            "id": "neurocode",
            "aliases": ["NeuroCode", "neurocode"],
            "extensions": [".neuro", ".nc"],
            "configuration": "./language_configuration.json",
            "icon": {
                "light": "./icon.png",
                "dark": "./icon.png"
            }
        }],
        "grammars": [{
            "language": "neurocode",
            "scopeName": "source.neuro",
            "path": "./syntaxes/neurocode.tmLanguage.json"
        }],
        "snippets": [{
            "language": "neurocode",
            "path": "./snippets/neurocode.json"
        }],
        "commands": [{
            "command": "neurocode.run",
            "title": "NeuroCode: Ejecutar Script",
            "category": "NeuroCode"
        }, {
            "command": "neurocode.test",
            "title": "NeuroCode: Ejecutar Tests",
            "category": "NeuroCode"
        }],
        "keybindings": [{
            "command": "neurocode.run",
            "key": "ctrl+f5",
            "when": "editorLangId == neurocode"
        }, {
            "command": "neurocode.test",
            "key": "ctrl+shift+f5",
            "when": "editorLangId == neurocode"
        }],
        "menus": {
            "editor/context": [{
                "command": "neurocode.run",
                "group": "navigation",
                "when": "editorLangId == neurocode"
            }]
        }
    }
}
